+	utool_reg_msg("clock_freq: 0x%x\n", dlphy_info.clock_freq);
 	utool_print_eth_dlphy_fec_info(dlphy_info.fec);
 	utool_print_eth_dlphy_mode_info(dlphy_info.phy_mode_ctrl);

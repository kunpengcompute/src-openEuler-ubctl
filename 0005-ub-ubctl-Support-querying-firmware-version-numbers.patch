diff --git a/doc/ubctl.pod b/doc/ubctl.pod
index 942cbce..5ae8c23 100644
--- a/doc/ubctl.pod
+++ b/doc/ubctl.pod
@@ -78,7 +78,7 @@ $ub_ctl_id: ub ctl id, required parameter, chip id and ub ctl id  are used to fi
 
 =item B<-m> ${module}
 
-$module: module name, required parameter, current module include: dl, ba, ta, nl, qos, tp, msgq, dump, ummu, port_info, ubommu, ecc_2b, queue, cmdq, uboe, port_pkt_stats.
+$module: module name, required parameter, current module include: dl, ba, ta, nl, qos, tp, msgq, dump, ummu, port_info, ubommu, ecc_2b, queue, cmdq, uboe, port_pkt_stats, fw_version.
 
 =item B<-f> ${function}
 
@@ -237,6 +237,9 @@ B<Query statistical indicators>:
 
  ubctl -c ${chip_id} -d ${ub_ctl_id} -m port_pkt_stats -p ${port_id}
 
+B<Query firmware version>:
+ ubctl -c ${chip_id} -d ${ub_ctl_id} -m fw_version
+

From d45296d20e77f1418a54c6883153d83991ea1b64 Mon Sep 17 00:00:00 2001
From: Jiaqi Cheng <chengjiaqi3@huawei.com>
Date: Thu, 26 Feb 2026 16:48:27 +0800
Subject: [PATCH 3/7] ub:ubctl:Support querying statistical indicators at the
 ub port and uboe port levels

driver inclusion
category: feature
bugzilla: https://atomgit.com/openeuler/ubctl/issues/9
CVE: NA

----------------------------------------------------------

ubctl support querying statistical indicators at the ub port and uboe port levels

Signed-off-by: Jiaqi Cheng <chengjiaqi3@huawei.com>
---
 doc/ubctl.pod             |   5 +-
 kernel_headers/ub_fwctl.h |   4 +
 u_utool_common.h          |   2 +
 u_utool_dispatch.c        |   2 +
 u_utool_main.c            |   3 +-
 u_utool_port_pkt.c        | 237 ++++++++++++++++++++++++++++++++++++++
 u_utool_port_pkt.h        |  17 +++
 7 files changed, 268 insertions(+), 2 deletions(-)
 create mode 100644 u_utool_port_pkt.c
 create mode 100644 u_utool_port_pkt.h

diff --git a/doc/ubctl.pod b/doc/ubctl.pod
index d03e07a..aa23524 100644
--- a/doc/ubctl.pod
+++ b/doc/ubctl.pod
@@ -78,7 +78,7 @@ $ub_ctl_id: ub ctl id, required parameter, chip id and ub ctl id  are used to fi
 
 =item B<-m> ${module}
 
-$module: module name, required parameter, current module include: dl, ba, ta, nl, qos, tp, msgq, dump, ummu, port_info, ubommu, ecc_2b, queue, cmdq, uboe.
+$module: module name, required parameter, current module include: dl, ba, ta, nl, qos, tp, msgq, dump, ummu, port_info, ubommu, ecc_2b, queue, cmdq, uboe, port_pkt_stats.
 
 =item B<-f> ${function}
 
@@ -231,6 +231,9 @@ B<Query queue information>:
 
  ubctl -c ${chip_id} -d ${ub_ctl_id} -m queue
 
+B<Query statistical indicators>:
+
+ ubctl -c ${chip_id} -d ${ub_ctl_id} -m port_pkt_stats -p ${port_id}
 
 =head1 COPYRIGHT
 
